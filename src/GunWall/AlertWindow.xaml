<Window
    x:Class="GunWall.AlertWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Network alert - GunWall"
    Width="400" SizeToContent="Height"
    WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
    ShowInTaskbar="False" Topmost="True"
    WindowStartupLocation="Manual"
    Background="Transparent"
    MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- Connection alert card: rounded, soft shadow, pin badge,
         title/subtitle, app + info, flag + endpoint, Allow / Block. -->
    <Border Background="{DynamicResource BgCard}" CornerRadius="14" Margin="14"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="4"
                              Direction="270" Opacity="0.32" />
        </Border.Effect>
        <Grid Margin="18,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header: pin badge + title/subtitle + close -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Pin-shaped badge with NEW -->
                <Grid Grid.Column="0" Width="46" Height="46" VerticalAlignment="Top" Margin="0,2,12,0">
                    <Ellipse Fill="{StaticResource Accent}" />
                    <Ellipse Width="40" Height="40" Fill="{DynamicResource BgCard}" />
                    <TextBlock Text="NEW" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource AllowBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderText" Text="First network access"
                               Style="{StaticResource H2}" TextWrapping="Wrap" />
                    <TextBlock Text="Outgoing connection" Style="{StaticResource Muted}"
                               Margin="0,1,0,0" />
                </StackPanel>

                <Button Grid.Column="2" Content="&#xE711;" Width="28" Height="28"
                        VerticalAlignment="Top"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                        Style="{StaticResource ActionButton}" BorderThickness="0"
                        Background="Transparent" Click="Close_Click" />
            </Grid>

            <!-- App name + signature + Info -->
            <Border Grid.Row="1" Background="{DynamicResource BgElevated}" CornerRadius="9"
                    Padding="12,10" Margin="0,14,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="NameText" Text="app.exe" FontWeight="SemiBold"
                                   FontSize="14" VerticalAlignment="Center" />
                        <Border Background="{DynamicResource AccentSoft}" CornerRadius="5"
                                Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Info" FontSize="10.5" Foreground="{StaticResource Accent}" />
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="SignatureText" Text="Checking signature..."
                               Style="{StaticResource Muted}" Margin="0,3,0,0" />
                </StackPanel>
            </Border>

            <!-- Endpoint details -->
            <StackPanel Grid.Row="2" Margin="2,12,2,0">
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Address" Style="{StaticResource Muted}" />
                    <TextBlock Grid.Column="1" x:Name="AddressText" Text="&#x2014;"
                               HorizontalAlignment="Right" />
                </Grid>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Host" Style="{StaticResource Muted}" />
                    <TextBlock Grid.Column="1" x:Name="HostText" Text="Resolving..."
                               HorizontalAlignment="Right" />
                </Grid>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Port" Style="{StaticResource Muted}" />
                    <TextBlock Grid.Column="1" x:Name="PortText" Text="&#x2014;"
                               HorizontalAlignment="Right" />
                </Grid>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Path" Style="{StaticResource Muted}" />
                    <TextBlock Grid.Column="1" x:Name="PathText" Text="&#x2014;"
                               HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Time" Style="{StaticResource Muted}" />
                    <TextBlock Grid.Column="1" x:Name="DateText" Text="&#x2014;"
                               HorizontalAlignment="Right" />
                </Grid>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="AllowButton" Margin="0,0,5,0" Padding="14,10"
                            Style="{StaticResource PrimaryButton}" Click="Allow_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,7,0" />
                            <TextBlock Text="Allow" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" x:Name="BlockButton" Margin="5,0,0,0" Padding="14,10"
                            Style="{StaticResource ActionButton}" Click="Block_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="13" Foreground="{StaticResource BlockBrush}"
                                       VerticalAlignment="Center" Margin="0,0,7,0" />
                            <TextBlock Text="Block" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                </Grid>
                <TextBlock x:Name="CountdownHint" Style="{StaticResource Muted}"
                           HorizontalAlignment="Center" Margin="0,8,0,0" Text="" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
