<Window
    x:Class="GunWall.AlertWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Network alert - GunWall"
    Width="480" SizeToContent="Height"
    WindowStyle="None" ResizeMode="NoResize"
    ShowInTaskbar="False" Topmost="True"
    WindowStartupLocation="Manual"
    Background="{StaticResource BgPrimary}"
    MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title row -->
            <Grid Grid.Row="0" Background="{StaticResource BgSecondary}">
                <TextBlock Text="Network alert - GunWall" Style="{StaticResource Muted}"
                           Margin="12,8" />
                <Button Content="X" Width="34" Height="26" HorizontalAlignment="Right"
                        Style="{StaticResource ActionButton}" BorderThickness="0"
                        Background="Transparent" Click="Close_Click" />
            </Grid>

            <!-- Accent header strip -->
            <Border Grid.Row="1" Background="{StaticResource Accent}" Padding="16,12">
                <TextBlock x:Name="HeaderText" Text="New app connected to the network"
                           FontSize="16" FontWeight="SemiBold" Foreground="#0E1117" TextWrapping="Wrap" />
            </Border>

            <!-- Detail rows -->
            <Grid Grid.Row="2" Margin="16,14,16,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="28" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Style="{StaticResource Muted}" />
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="NameText" HorizontalAlignment="Right"
                           FontWeight="SemiBold" Foreground="{StaticResource Accent}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Signature:" Style="{StaticResource Muted}" />
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SignatureText" HorizontalAlignment="Right" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Address:" Style="{StaticResource Muted}" />
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="AddressText" HorizontalAlignment="Right" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Host:" Style="{StaticResource Muted}" />
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="HostText" HorizontalAlignment="Right"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Port:" Style="{StaticResource Muted}" />
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="PortText" HorizontalAlignment="Right" />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Path:" Style="{StaticResource Muted}" />
                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="PathText" HorizontalAlignment="Right"
                           TextTrimming="CharacterEllipsis" FontSize="11"
                           Foreground="{StaticResource TextSecondary}" />

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Date:" Style="{StaticResource Muted}" />
                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="DateText" HorizontalAlignment="Right" />
            </Grid>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Margin="16,8,16,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="AllowButton" Margin="0,0,6,0" Padding="14,10"
                            Style="{StaticResource ActionButton}" Click="Allow_Click">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="{StaticResource AllowBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Allow" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" x:Name="BlockButton" Margin="6,0,0,0" Padding="14,10"
                            Style="{StaticResource ActionButton}" Click="Block_Click">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="{StaticResource BlockBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Block" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                </Grid>
                <TextBlock x:Name="CountdownHint" Style="{StaticResource Muted}"
                           HorizontalAlignment="Center" Margin="0,8,0,0" Text="" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
