<Window
    x:Class="GunWall.AppPropertiesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Application properties - GunWall"
    Width="520" SizeToContent="Height"
    WindowStyle="SingleBorderWindow" ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    Background="{DynamicResource BgPrimary}">

    <Border Background="{DynamicResource BgCard}" CornerRadius="12" Margin="14"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <StackPanel Margin="22,20">

            <!-- Header: icon + name -->
            <StackPanel Orientation="Horizontal">
                <Image x:Name="IconImage" Width="32" Height="32" VerticalAlignment="Center"
                       Margin="0,0,12,0" SnapsToDevicePixels="True" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="NameText" FontWeight="SemiBold" FontSize="16"
                               Foreground="{DynamicResource TextPrimary}" />
                    <TextBlock x:Name="SignatureText" FontSize="12" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,16" />

            <!-- Detail rows -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Publisher" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8" />
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PublisherText" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" Margin="0,0,0,8" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Status" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8" />
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="StatusText" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Connections" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8" />
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ConnText" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Path" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8" />
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="PathText" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" Margin="0,0,0,8" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="SHA-256" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8" />
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="HashText" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"
                           FontFamily="Consolas" FontSize="11" Margin="0,0,0,8" />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Signature" Foreground="{DynamicResource TextSecondary}" />
                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="DetailText" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" />
            </Grid>

            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,16" />

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Allow" Click="Allow_Click" Style="{StaticResource ActionButton}" Margin="0,0,8,0" />
                <Button Content="Block" Click="Block_Click" Style="{StaticResource ActionButton}" Margin="0,0,8,0" />
                <Button Content="Open file location" Click="OpenLocation_Click" Style="{StaticResource ActionButton}" Margin="0,0,8,0" />
                <Button Content="Copy path" Click="CopyPath_Click" Style="{StaticResource ActionButton}" Margin="0,0,8,0" />
                <Button Content="Close" Click="Close_Click" Style="{StaticResource PrimaryButton}" />
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
