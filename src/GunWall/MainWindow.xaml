<Window
    x:Class="GunWall.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:GunWall.Converters"
    xmlns:svc="clr-namespace:GunWall.Services"
    Title="GunWall"
    Height="760" Width="1180"
    MinHeight="640" MinWidth="1000"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource BgPrimary}">

    <Window.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrush" />
        <conv:StatusToFillConverter x:Key="StatusToFill" />
        <conv:StatusToActionTextConverter x:Key="StatusToAction" />
        <conv:StatusToTextConverter x:Key="StatusToText" />
        <conv:CategoryToBrushConverter x:Key="CategoryToBrush" />
        <conv:CategoryToTextConverter x:Key="CategoryToText" />
        <conv:ProtectLabelConverter x:Key="ProtectLabel" />
        <conv:CountryFlagConverter x:Key="CountryFlag" />
        <conv:NameToBrushConverter x:Key="NameToBrush" />
        <conv:NameInitialConverter x:Key="NameInitial" />
        <conv:NullToVisibleConverter x:Key="NullToVisible" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BgSecondary}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
            <Setter Property="Width" Value="220" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="218" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===================== Sidebar navigation ===================== -->
        <Border Grid.Column="0" Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="20,20,16,14">
                    <TextBlock Text="GunWall" Style="{StaticResource H2}" />
                    <TextBlock Text="Guard Your Network" Style="{StaticResource Muted}" Margin="0,1,0,0" />
                </StackPanel>
                <Border DockPanel.Dock="Top" Margin="12,0,12,12" Padding="12,11" CornerRadius="10"
                        Background="{DynamicResource BgCard}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="SideStatusIcon" Text="&#xEA18;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="20"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="SideStatusTitle" Text="Monitoring Only" FontSize="12.5"
                                       FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                            <TextBlock x:Name="SideStatusSub" Text="Watching, not blocking" FontSize="10"
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,1,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,2,0,12">
                        <RadioButton x:Name="NavDashboard" Style="{StaticResource SideNavButton}" IsChecked="True" Checked="Nav_Checked" Tag="Dashboard">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SideNavIcon}" Text="&#xE9D9;" />
                                <TextBlock Style="{StaticResource SideNavLabel}" Text="Dashboard" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavFirewall" Style="{StaticResource SideNavButton}" Checked="Nav_Checked" Tag="Firewall">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SideNavIcon}" Text="&#xE71D;" />
                                <TextBlock Style="{StaticResource SideNavLabel}" Text="Apps" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavConnections" Style="{StaticResource SideNavButton}" Checked="Nav_Checked" Tag="Connections">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SideNavIcon}" Text="&#xE968;" />
                                <TextBlock Style="{StaticResource SideNavLabel}" Text="Connections" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavTraffic" Style="{StaticResource SideNavButton}" Checked="Nav_Checked" Tag="Traffic">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SideNavIcon}" Text="&#xE774;" />
                                <TextBlock Style="{StaticResource SideNavLabel}" Text="Traffic" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavDns" Style="{StaticResource SideNavButton}" Checked="Nav_Checked" Tag="Dns">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SideNavIcon}" Text="&#xE71C;" />
                                <TextBlock Style="{StaticResource SideNavLabel}" Text="DNS" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavServices" Style="{StaticResource SideNavButton}" Checked="Nav_Checked" Tag="Services">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SideNavIcon}" Text="&#xE9F5;" />
                                <TextBlock Style="{StaticResource SideNavLabel}" Text="Services" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavNetwork" Style="{StaticResource SideNavButton}" Checked="Nav_Checked" Tag="Network">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SideNavIcon}" Text="&#xE839;" />
                                <TextBlock Style="{StaticResource SideNavLabel}" Text="Network" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavPackets" Style="{StaticResource SideNavButton}" Checked="Nav_Checked" Tag="Packets">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SideNavIcon}" Text="&#xE9D2;" />
                                <TextBlock Style="{StaticResource SideNavLabel}" Text="Packets Log" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavRules" Style="{StaticResource SideNavButton}" Checked="Nav_Checked" Tag="Rules">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SideNavIcon}" Text="&#xE90F;" />
                                <TextBlock Style="{StaticResource SideNavLabel}" Text="Custom Rules" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavSystem" Style="{StaticResource SideNavButton}" Checked="Nav_Checked" Tag="System">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SideNavIcon}" Text="&#xE72E;" />
                                <TextBlock Style="{StaticResource SideNavLabel}" Text="System Rules" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavSecurity" Style="{StaticResource SideNavButton}" Checked="Nav_Checked" Tag="Security">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SideNavIcon}" Text="&#xEA18;" />
                                <TextBlock Style="{StaticResource SideNavLabel}" Text="Security" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavActivity" Style="{StaticResource SideNavButton}" Checked="Nav_Checked" Tag="Activity">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SideNavIcon}" Text="&#xE9F9;" />
                                <TextBlock Style="{StaticResource SideNavLabel}" Text="Activity" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavAlerts" Style="{StaticResource SideNavButton}" Checked="Nav_Checked" Tag="Alerts">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SideNavIcon}" Text="&#xE7E7;" />
                                <TextBlock x:Name="AlertsNavLabel" Style="{StaticResource SideNavLabel}" Text="Alerts" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavSettings" Style="{StaticResource SideNavButton}" Checked="Nav_Checked" Tag="Settings">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SideNavIcon}" Text="&#xE713;" />
                                <TextBlock Style="{StaticResource SideNavLabel}" Text="Settings" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===================== Main column ===================== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top bar: engine controls -->
            <Border Grid.Row="0" Background="{DynamicResource BgSecondary}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="20,12">
                    <ToggleButton x:Name="ThemeToggle" Style="{StaticResource ThemeSwitch}"
                                  Click="ThemeToggle_Click" Margin="0,0,16,0"
                                  ToolTip="Switch light / dark theme" />
                    <TextBlock x:Name="EngineStatus" Text="Engine: starting"
                               Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,16,0" />
                    <Button x:Name="LockdownButton" Content="Engage lockdown"
                            Style="{StaticResource ActionButton}" Margin="0,0,10,0"
                            Click="LockdownButton_Click" />
                    <Button x:Name="EnableFirewallButton" Content="Enable Firewall"
                            Style="{StaticResource PrimaryButton}" Click="EnableFirewall_Click" />
                </StackPanel>
            </Border>

            <!-- ===================== Content area ===================== -->
            <Grid Grid.Row="1" Margin="24" x:Name="PanelHost" RenderTransformOrigin="0.5,0">
                <Grid.RenderTransform><TranslateTransform x:Name="PanelHostShift" /></Grid.RenderTransform>

            <!-- ========== Dashboard ========== -->
            <Grid x:Name="PanelDashboard">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Dashboard" Style="{StaticResource H1}" Margin="0,0,0,12" />
                    <Border x:Name="StatusBanner" Style="{StaticResource Card}" Padding="24,20">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="72" Height="72" VerticalAlignment="Center">
                                <Ellipse x:Name="ShieldGlow" Fill="{StaticResource AllowFill}" />
                                <Viewbox Width="46" Height="46" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid Width="48" Height="48">
                                        <Path x:Name="ShieldPath"
                                              Data="M24,3 L42,10 L42,24 C42,34.5 34.5,43 24,46 C13.5,43 6,34.5 6,24 L6,10 Z"
                                              Fill="{StaticResource AllowBrush}" />
                                        <Path x:Name="ShieldCheck" Data="M16,24.5 L21.5,30 L32.5,18"
                                              Stroke="White" StrokeThickness="3.6"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                        <Path x:Name="ShieldAlert" Data="M18.5,18.5 L29.5,29.5 M29.5,18.5 L18.5,29.5"
                                              Stroke="White" StrokeThickness="3.6"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Visibility="Collapsed" />
                                    </Grid>
                                </Viewbox>
                            </Grid>
                            <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="StatusTitle" Text="Protected"
                                           FontWeight="Bold" FontSize="22" />
                                <TextBlock x:Name="StatusSub" Style="{StaticResource Muted}" FontSize="13"
                                           Margin="0,3,0,0" TextWrapping="Wrap" MaxWidth="560"
                                           Text="Alert mode - new apps are allowed and you get notified" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Padding="14,12" Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                                <StackPanel Margin="0,0,28,8" Background="Transparent" Cursor="Hand"
                                            Tag="Firewall" MouseLeftButtonUp="Stat_Click"
                                            ToolTip="Open the Apps list">
                                    <TextBlock x:Name="StatApps" Text="0" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Apps seen" Style="{StaticResource Muted}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,28,8" Background="Transparent" Cursor="Hand"
                                            Tag="Firewall" MouseLeftButtonUp="Stat_Click"
                                            ToolTip="Open the Apps list">
                                    <TextBlock x:Name="StatBlocked" Text="0" FontSize="20" FontWeight="SemiBold"
                                               Foreground="{StaticResource BlockBrush}" />
                                    <TextBlock Text="Blocked" Style="{StaticResource Muted}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,28,8" Background="Transparent" Cursor="Hand"
                                            Tag="Firewall" MouseLeftButtonUp="Stat_Click"
                                            ToolTip="Open the Apps list">
                                    <TextBlock x:Name="StatAllowed" Text="0" FontSize="20" FontWeight="SemiBold"
                                               Foreground="{StaticResource AllowBrush}" />
                                    <TextBlock Text="Allowed" Style="{StaticResource Muted}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,28,8" Background="Transparent" Cursor="Hand"
                                            Tag="Rules" MouseLeftButtonUp="Stat_Click"
                                            ToolTip="Open Custom Rules">
                                    <TextBlock x:Name="StatRules" Text="0" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Custom rules" Style="{StaticResource Muted}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,28,8" Background="Transparent" Cursor="Hand"
                                            Tag="System" MouseLeftButtonUp="Stat_Click"
                                            ToolTip="Open System Rules">
                                    <TextBlock x:Name="StatSystem" Text="0" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="System rules" Style="{StaticResource Muted}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8" Background="Transparent" Cursor="Hand"
                                            Tag="Rules" MouseLeftButtonUp="Stat_Click"
                                            ToolTip="Open the IP blocklist">
                                    <TextBlock x:Name="StatBlocklist" Text="0" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Blocklisted" Style="{StaticResource Muted}" />
                                </StackPanel>
                            </WrapPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="SnoozeStatus" Style="{StaticResource Muted}"
                                           HorizontalAlignment="Right" Margin="0,0,0,6" Text="" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Snooze 15 min" Style="{StaticResource ActionButton}"
                                            Click="Snooze_Click" Tag="15" Margin="0,0,8,0" />
                                    <Button Content="Snooze 1 hr" Style="{StaticResource ActionButton}"
                                            Click="Snooze_Click" Tag="60" Margin="0,0,8,0" />
                                    <Button x:Name="ResumeButton" Content="Resume" Style="{StaticResource ActionButton}"
                                            Click="Resume_Click" Visibility="Collapsed" />
                                </StackPanel>
                                <Button Content="Check for updates" Style="{StaticResource ActionButton}"
                                        Click="CheckUpdate_Click" HorizontalAlignment="Right" Margin="0,8,0,0" />
                                <TextBlock x:Name="UpdateStatus" Style="{StaticResource Muted}"
                                           HorizontalAlignment="Right" Margin="0,6,0,0"
                                           TextWrapping="Wrap" MaxWidth="280" TextAlignment="Right" Text="" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Download" Style="{StaticResource Muted}" />
                            <TextBlock x:Name="DownSpeed" Text="0 KB/s"
                                       FontSize="24" FontWeight="SemiBold"
                                       Foreground="{StaticResource InboundBrush}" Margin="0,4,0,0" />
                            <TextBlock x:Name="SessionDown" Text="Session: 0 B"
                                       Style="{StaticResource Muted}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Upload" Style="{StaticResource Muted}" />
                            <TextBlock x:Name="UpSpeed" Text="0 KB/s"
                                       FontSize="24" FontWeight="SemiBold"
                                       Foreground="{StaticResource OutboundBrush}" Margin="0,4,0,0" />
                            <TextBlock x:Name="SessionUp" Text="Session: 0 B"
                                       Style="{StaticResource Muted}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Active connections" Style="{StaticResource Muted}" />
                            <TextBlock x:Name="ConnCount" Text="0"
                                       FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="THROUGHPUT (LAST 60S)" Style="{StaticResource SectionLabel}" />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource InboundBrush}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="Down" Style="{StaticResource Muted}" Margin="6,0,16,0" />
                                <Ellipse Width="10" Height="10" Fill="{StaticResource OutboundBrush}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="Up" Style="{StaticResource Muted}" Margin="6,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Canvas x:Name="GraphCanvas" ClipToBounds="True" Background="Transparent"
                                    SizeChanged="GraphCanvas_SizeChanged"
                                    MouseMove="GraphCanvas_MouseMove" MouseLeave="GraphCanvas_MouseLeave" />
                            <Canvas x:Name="GraphOverlay" IsHitTestVisible="False" ClipToBounds="True">
                                <Rectangle x:Name="GraphCursorLine" Width="1" Fill="#55FFFFFF"
                                           Visibility="Collapsed" />
                                <Border x:Name="GraphTooltip" Visibility="Collapsed" CornerRadius="6"
                                        Background="{DynamicResource BgElevated}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        Padding="9,6">
                                    <StackPanel>
                                        <TextBlock x:Name="GraphTooltipTime" FontSize="10"
                                                   Foreground="{DynamicResource TextSecondary}" />
                                        <TextBlock x:Name="GraphTooltipDown" FontSize="11.5" FontWeight="SemiBold"
                                                   Foreground="{StaticResource InboundBrush}" />
                                        <TextBlock x:Name="GraphTooltipUp" FontSize="11.5"
                                                   Foreground="{StaticResource OutboundBrush}" />
                                    </StackPanel>
                                </Border>
                            </Canvas>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========== Firewall ========== -->
            <Grid x:Name="PanelFirewall" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" ClipToBounds="True">
                            <TextBlock Text="Firewall" Style="{StaticResource H1}" VerticalAlignment="Center" />
                            <CheckBox x:Name="ShowAllAppsCheck" Content="Show all running apps"
                                      Foreground="{DynamicResource TextSecondary}"
                                      VerticalAlignment="Center" Margin="24,4,0,0"
                                      Checked="ShowAllApps_Changed" Unchecked="ShowAllApps_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBox x:Name="AppSearch" Style="{StaticResource SearchBox}"
                                     TextChanged="AppSearch_TextChanged" Margin="0,0,8,0"
                                     ToolTip="Search applications" />
                            <Button Content="Block an app" Style="{StaticResource ActionButton}"
                                    Click="BrowseBlock_Click" Margin="0,0,8,0" />
                            <Button Content="Purge unused" Style="{StaticResource ActionButton}"
                                    Click="PurgeUnused_Click" Margin="0,0,8,0"
                                    ToolTip="Forget apps that have no allow/block rule (they'll prompt again)" />
                            <Button Content="Purge expired timers" Style="{StaticResource ActionButton}"
                                    Click="PurgeExpiredTimers_Click" Margin="0,0,8,0"
                                    ToolTip="Clear any timed blocks whose timer has already elapsed" />
                            <Button Content="Refresh" Style="{StaticResource ActionButton}"
                                    Click="RefreshApps_Click" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,12,0,0">
                        <Ellipse Width="9" Height="9" Fill="#30D158" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBlock Text="Signed" Style="{StaticResource Muted}" Margin="0,0,12,0" />
                        <Ellipse Width="9" Height="9" Fill="#FF9F0A" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBlock Text="Unsigned" Style="{StaticResource Muted}" Margin="0,0,12,0" />
                        <Ellipse Width="9" Height="9" Fill="#0A84FF" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBlock Text="System" Style="{StaticResource Muted}" Margin="0,0,12,0" />
                        <Ellipse Width="9" Height="9" Fill="#FF453A" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBlock Text="Invalid sig" Style="{StaticResource Muted}" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8">
                    <ListView x:Name="AppsList" VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              PreviewMouseRightButtonDown="Row_RightClickSelect">
                        <ListView.ContextMenu>
                            <ContextMenu Opened="AppsContextMenu_Opened">
                                <MenuItem Header="Mute (allow, no popups)" Click="MuteApp_Click" />
                                <MenuItem Header="Unmute" Click="UnmuteApp_Click" />
                                <Separator />
                                <MenuItem Header="Scan with VirusTotal" Click="ScanVt_Click" />
                                <Separator />
                                <MenuItem Header="Block outbound only" Click="BlockDirection_Click" Tag="out" />
                                <MenuItem Header="Block inbound only" Click="BlockDirection_Click" Tag="in" />
                                <MenuItem Header="Block by network scope">
                                    <MenuItem x:Name="ScopeLocalItem" Header="Block device-local (loopback)"
                                              IsCheckable="True" Click="ScopeBlock_Click" Tag="local" />
                                    <MenuItem x:Name="ScopeLanItem" Header="Block local network (LAN)"
                                              IsCheckable="True" Click="ScopeBlock_Click" Tag="lan" />
                                    <MenuItem x:Name="ScopeIncomingItem" Header="Block incoming connections"
                                              IsCheckable="True" Click="ScopeBlock_Click" Tag="incoming" />
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="Block for 15 minutes" Click="BlockTemp_Click" Tag="15" />
                                <MenuItem Header="Block for 1 hour" Click="BlockTemp_Click" Tag="60" />
                                <MenuItem Header="Copy path" Click="CopyPath_Click" />
                                <MenuItem Header="Open file location" Click="OpenLocation_Click" />
                                <Separator />
                                <MenuItem Header="Properties..." Click="Properties_Click" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Application" Width="220">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Grid Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Ellipse Fill="{Binding Name, Converter={StaticResource NameToBrush}}"
                                                             Visibility="{Binding Icon, Converter={StaticResource NullToVisible}}" />
                                                    <TextBlock Text="{Binding Name, Converter={StaticResource NameInitial}}"
                                                               Foreground="#F2F4F6" FontSize="11" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Visibility="{Binding Icon, Converter={StaticResource NullToVisible}}" />
                                                    <Image Source="{Binding Icon}" Width="22" Height="22"
                                                           SnapsToDevicePixels="True" />
                                                </Grid>
                                                <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                                                         Margin="0,0,8,0"
                                                         Fill="{Binding Category, Converter={StaticResource CategoryToBrush}}"
                                                         ToolTip="{Binding Category, Converter={StaticResource CategoryToText}}" />
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                <Border CornerRadius="4" Padding="5,1" Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Background="{DynamicResource AccentSoft}"
                                                        Visibility="{Binding IsStoreApp, Converter={StaticResource BoolToVis}}"
                                                        ToolTip="{Binding PackageFamily}">
                                                    <TextBlock Text="Store" FontSize="9.5"
                                                               Foreground="{DynamicResource TextSecondary}" />
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Publisher" Width="190"
                                                DisplayMemberBinding="{Binding Publisher}" />
                                <GridViewColumn Header="VirusTotal" Width="130">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding VtText}" FontSize="12"
                                                       ToolTip="Automatic reputation check: only the file's SHA-256 hash is sent to VirusTotal, never the file.">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding VtLevel}" Value="clean">
                                                                <Setter Property="Foreground" Value="{DynamicResource AllowText}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding VtLevel}" Value="flagged">
                                                                <Setter Property="Foreground" Value="{DynamicResource BlockText}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Path" Width="300"
                                                DisplayMemberBinding="{Binding ExecutablePath}" />
                                <GridViewColumn Header="Conns" Width="86">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="9" Padding="8,2" HorizontalAlignment="Left"
                                                    Background="{DynamicResource BgElevated}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding ActiveConnections}" FontSize="11"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextPrimary}" />
                                                    <Rectangle Width="16" Height="4" RadiusX="2" RadiusY="2"
                                                               Margin="6,0,0,0" VerticalAlignment="Center"
                                                               Fill="{DynamicResource AllowText}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Status" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="10,3"
                                                    HorizontalAlignment="Left"
                                                    Background="{Binding Status, Converter={StaticResource StatusToFill}}">
                                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                                           Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"
                                                           FontSize="11.5" FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Action" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Status, Converter={StaticResource StatusToAction}}"
                                                    Style="{StaticResource ActionButton}"
                                                    Padding="10,4"
                                                    Click="ToggleApp_Click" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Grid>

            <!-- ========== Connections ========== -->
            <Grid x:Name="PanelConnections" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Connections" Style="{StaticResource H1}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="GeoStatus" Style="{StaticResource Muted}"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Button x:Name="GeoDownloadBtn" Content="Download GeoIP data"
                                Style="{StaticResource ActionButton}" Click="GeoDownload_Click"
                                Margin="0,0,8,0"
                                ToolTip="Fetch the free country/ASN database so each connection shows its location" />
                        <TextBox x:Name="ConnSearch" Style="{StaticResource SearchBox}"
                                 TextChanged="ConnSearch_TextChanged" ToolTip="Search connections" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8">
                    <ListView x:Name="ConnList" VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              SelectionChanged="ConnSelected"
                              PreviewMouseRightButtonDown="Row_RightClickSelect">
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Close this connection" Click="CloseConn_Click" />
                                <MenuItem Header="Block this app" Click="BlockConnApp_Click" />
                                <MenuItem Header="Block app and close connections" Click="BlockAndCloseConn_Click" />
                                <Separator />
                                <MenuItem Header="End process (terminate)" Click="KillProcess_Click" />
                                <Separator />
                                <MenuItem Header="Copy remote address" Click="CopyConnRemote_Click" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Process" Width="170"
                                                DisplayMemberBinding="{Binding ProcessName}" />
                                <GridViewColumn Header="PID" Width="64"
                                                DisplayMemberBinding="{Binding ProcessId}" />
                                <GridViewColumn Header="Proto" Width="56"
                                                DisplayMemberBinding="{Binding Protocol}" />
                                <GridViewColumn Header="Local" Width="190"
                                                DisplayMemberBinding="{Binding LocalEndpoint}" />
                                <GridViewColumn Header="Remote" Width="220"
                                                DisplayMemberBinding="{Binding RemoteEndpoint}" />
                                <GridViewColumn Header="Location" Width="210">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Width="20" Height="14" Margin="0,0,7,0"
                                                       VerticalAlignment="Center" Stretch="Uniform"
                                                       SnapsToDevicePixels="True"
                                                       Source="{Binding Country, Converter={StaticResource CountryFlag}}" />
                                                <TextBlock Text="{Binding Location}" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="State" Width="100"
                                                DisplayMemberBinding="{Binding State}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <!-- ===== §11 master-detail inspector ===== -->
                <Border Grid.Column="1" Width="340" Margin="12,0,0,0"
                        Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <TextBlock x:Name="InspPlaceholder"
                                   Text="Select a connection to inspect its full details."
                                   Style="{StaticResource Muted}" TextWrapping="Wrap"
                                   TextAlignment="Center" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Margin="28" />
                        <ScrollViewer x:Name="InspContent" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto" Padding="18,16">
                            <StackPanel>
                                <TextBlock x:Name="InspProcess" Style="{StaticResource H2}" TextWrapping="Wrap" />
                                <TextBlock x:Name="InspSub" Style="{StaticResource Muted}" FontSize="12" Margin="0,2,0,0" />

                                <TextBlock Text="CONNECTION" Style="{StaticResource Muted}" FontSize="10.5" Margin="0,18,0,4" />
                                <Grid Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Type" Style="{StaticResource Muted}" FontSize="12" />
                                    <TextBlock Grid.Column="1" x:Name="InspType" FontSize="12" TextWrapping="Wrap" />
                                </Grid>
                                <Grid Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Local" Style="{StaticResource Muted}" FontSize="12" />
                                    <TextBlock Grid.Column="1" x:Name="InspLocal" FontSize="12" TextWrapping="Wrap" />
                                </Grid>
                                <Grid Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Remote" Style="{StaticResource Muted}" FontSize="12" />
                                    <TextBlock Grid.Column="1" x:Name="InspRemote" FontSize="12" TextWrapping="Wrap" />
                                </Grid>
                                <Grid Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="State" Style="{StaticResource Muted}" FontSize="12" />
                                    <TextBlock Grid.Column="1" x:Name="InspState" FontSize="12" TextWrapping="Wrap" />
                                </Grid>

                                <TextBlock Text="LOCATION" Style="{StaticResource Muted}" FontSize="10.5" Margin="0,18,0,4" />
                                <StackPanel x:Name="InspLocRow" Orientation="Horizontal" Margin="0,3,0,0">
                                    <Image x:Name="InspFlag" Width="34" Height="24" Margin="0,0,9,0"
                                           VerticalAlignment="Center" Stretch="Uniform" SnapsToDevicePixels="True" />
                                    <TextBlock x:Name="InspCountry" VerticalAlignment="Center" TextWrapping="Wrap" FontWeight="SemiBold" />
                                </StackPanel>
                                <Grid x:Name="InspAsnRow" Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="ASN" Style="{StaticResource Muted}" FontSize="12" />
                                    <TextBlock Grid.Column="1" x:Name="InspAsn" FontSize="12" TextWrapping="Wrap" />
                                </Grid>
                                <Grid x:Name="InspOwnerRow" Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Operator" Style="{StaticResource Muted}" FontSize="12" />
                                    <TextBlock Grid.Column="1" x:Name="InspOwner" FontSize="12" TextWrapping="Wrap" />
                                </Grid>

                                <TextBlock Text="APPLICATION" Style="{StaticResource Muted}" FontSize="10.5" Margin="0,18,0,4" />
                                <Grid Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Path" Style="{StaticResource Muted}" FontSize="12" />
                                    <TextBlock Grid.Column="1" x:Name="InspPath" FontSize="12" TextWrapping="Wrap" />
                                </Grid>
                                <Grid Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Why" Style="{StaticResource Muted}" FontSize="12" />
                                    <TextBlock Grid.Column="1" x:Name="InspVerdict" FontSize="12" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextSecondary}" />
                                </Grid>
                                <Grid Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Policy" Style="{StaticResource Muted}" FontSize="12" />
                                    <TextBlock Grid.Column="1" x:Name="InspStatus" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                                </Grid>
                                <Grid x:Name="InspScopeRow" Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Scope" Style="{StaticResource Muted}" FontSize="12" />
                                    <TextBlock Grid.Column="1" x:Name="InspScope" FontSize="12" TextWrapping="Wrap" />
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                </Grid>
            </Grid>

            <!-- ========== Traffic ========== -->
            <Grid x:Name="PanelTraffic" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Traffic" Style="{StaticResource H1}" />
                        <TextBlock x:Name="TrafficSubtitle"
                                   Text="Where your traffic has gone since GunWall started."
                                   Style="{StaticResource Muted}" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14" Margin="0,0,0,16">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="CONNECTION MAP" Style="{StaticResource Muted}"
                                   FontSize="11" FontWeight="SemiBold" Margin="2,0,0,10" />
                        <Viewbox Stretch="Uniform" MaxHeight="320" HorizontalAlignment="Stretch">
                            <Grid Width="1000" Height="500">
                                <Path Data="{Binding Source={x:Static svc:WorldMapData.LandPathData}}"
                                      Fill="#20272B" Stroke="#333A3F" StrokeThickness="0.4" />
                                <Canvas x:Name="MapMarkers" Width="1000" Height="500" />
                            </Grid>
                        </Viewbox>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}" Padding="14" Margin="0,0,8,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="TOP COUNTRIES" Style="{StaticResource SectionLabel}" Margin="0,0,0,10" />
                            <ListView x:Name="TrafficCountries" BorderThickness="0" Background="Transparent"
                                      VirtualizingPanel.IsVirtualizing="True">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Country" Width="240">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Width="22" Height="15" Margin="0,0,9,0" VerticalAlignment="Center"
                                                               Stretch="Uniform" SnapsToDevicePixels="True"
                                                               Source="{Binding Code, Converter={StaticResource CountryFlag}}" />
                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Destinations" Width="120" DisplayMemberBinding="{Binding Count}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}" Padding="14" Margin="8,0,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="MOST ACTIVE APPS" Style="{StaticResource SectionLabel}" Margin="0,0,0,10" />
                            <ListView x:Name="TrafficApps" BorderThickness="0" Background="Transparent"
                                      VirtualizingPanel.IsVirtualizing="True">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Application" Width="210" DisplayMemberBinding="{Binding Name}" />
                                        <GridViewColumn Header="Destinations" Width="110" DisplayMemberBinding="{Binding Count}" />
                                        <GridViewColumn Header="Countries" Width="90" DisplayMemberBinding="{Binding Countries}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </Border>
                </Grid>
            
                <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,16,0,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="DATA USAGE BY APP" Style="{StaticResource Muted}"
                                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ComboBox x:Name="UsageWindowCombo" Width="140" HorizontalAlignment="Right"
                                      SelectionChanged="UsageWindow_Changed" SelectedIndex="1">
                                <ComboBoxItem Content="Last 5 minutes" />
                                <ComboBoxItem Content="Last hour" />
                                <ComboBoxItem Content="Last 24 hours" />
                            </ComboBox>
                        </DockPanel>
                        <TextBlock x:Name="UsageModeText" DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,0,0,8" TextWrapping="Wrap"
                                   Text="Estimated: totals are attributed to apps by their share of active connections in each interval. Pick a short window right after a spike to see what caused it." />
                        <TextBlock DockPanel.Dock="Top" Text="APPS USAGE TIMELINE"
                                   Style="{StaticResource SectionLabel}" Margin="0,2,0,6" />
                        <Border DockPanel.Dock="Top" Height="64" CornerRadius="6" Margin="0,0,0,6"
                                Background="{DynamicResource BgElevated}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                ClipToBounds="True">
                            <Grid>
                                <Canvas x:Name="UsageStripCanvas" Background="Transparent" Cursor="Cross"
                                        SizeChanged="UsageStrip_SizeChanged"
                                        MouseLeftButtonDown="UsageStrip_MouseDown"
                                        MouseMove="UsageStrip_MouseMove"
                                        MouseLeftButtonUp="UsageStrip_MouseUp" />
                                <Canvas x:Name="UsageStripOverlay" IsHitTestVisible="False" ClipToBounds="True">
                                    <Rectangle x:Name="UsageSelRect" Fill="#2EFFFFFF" Visibility="Collapsed" />
                                    <Rectangle x:Name="UsageSelHandleL" Width="2.5" Fill="#0A84FF" Visibility="Collapsed" />
                                    <Rectangle x:Name="UsageSelHandleR" Width="2.5" Fill="#0A84FF" Visibility="Collapsed" />
                                </Canvas>
                            </Grid>
                        </Border>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8" LastChildFill="True">
                            <Button x:Name="UsageRangeClearBtn" DockPanel.Dock="Right" Content="Show whole window"
                                    Style="{StaticResource ActionButton}" Padding="10,3"
                                    Visibility="Collapsed" Click="UsageRangeClear_Click" />
                            <TextBlock x:Name="UsageRangeText" Style="{StaticResource Muted}"
                                       VerticalAlignment="Center" TextWrapping="Wrap"
                                       Text="Drag from point A to point B on the timeline to see which apps were active then, busiest first." />
                        </DockPanel>
                        <ListView x:Name="UsageList" BorderThickness="0" Background="Transparent" MaxHeight="260"
                                  VirtualizingPanel.IsVirtualizing="True">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Application" Width="280" DisplayMemberBinding="{Binding App}" />
                                    <GridViewColumn Header="Down" Width="110" DisplayMemberBinding="{Binding DownText}" />
                                    <GridViewColumn Header="Up" Width="110" DisplayMemberBinding="{Binding UpText}" />
                                    <GridViewColumn Header="Total" Width="120" DisplayMemberBinding="{Binding TotalText}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,16,0,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <TextBlock Text="TRAFFIC BREAKDOWN" Style="{StaticResource SectionLabel}"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="BreakSubtitle" Style="{StaticResource Muted}" FontSize="11"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Text="Session totals - estimated per-connection attribution" />
                        </DockPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.Resources>
                                <DataTemplate x:Key="BreakRowTemplate">
                                    <StackPanel Margin="0,0,16,9" ToolTip="{Binding Tip}">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Value}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondary}" Margin="8,0,0,0" />
                                            <TextBlock Text="{Binding Name}" FontSize="11.5"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                        <Border Height="3" CornerRadius="1.5" Background="#0A84FF"
                                                Width="{Binding BarWidth}" HorizontalAlignment="Left"
                                                Margin="0,3,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </Grid.Resources>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Apps" Style="{StaticResource Muted}" FontSize="11"
                                           FontWeight="SemiBold" Margin="0,0,0,8" />
                                <ItemsControl x:Name="BreakApps" ItemTemplate="{StaticResource BreakRowTemplate}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Hosts" Style="{StaticResource Muted}" FontSize="11"
                                           FontWeight="SemiBold" Margin="0,0,0,8" />
                                <ItemsControl x:Name="BreakHosts" ItemTemplate="{StaticResource BreakRowTemplate}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Traffic type" Style="{StaticResource Muted}" FontSize="11"
                                           FontWeight="SemiBold" Margin="0,0,0,8" />
                                <ItemsControl x:Name="BreakTypes" ItemTemplate="{StaticResource BreakRowTemplate}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Countries" Style="{StaticResource Muted}" FontSize="11"
                                           FontWeight="SemiBold" Margin="0,0,0,8" />
                                <ItemsControl x:Name="BreakCountries" ItemTemplate="{StaticResource BreakRowTemplate}" />
                            </StackPanel>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- ========== DNS resolver ========== -->
            <Grid x:Name="PanelDns" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- header -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="DNS resolver" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap"
                                   MaxWidth="960" HorizontalAlignment="Left"
                                   Text="GunWall's own local resolver. It logs every domain your apps look up, blocks the ones you list, and caches answers so repeat lookups are instant. It binds to 127.0.0.1 only. Flip 'Route this PC's DNS through GunWall' to send every app's lookups through it (captured and auto-restored on exit), and use Gaming Session for a one-tap zero-overhead bypass during matches. This is separate from Security -&gt; Filtering DNS, which only picks an upstream provider." />
                    </StackPanel>
                </Grid>

                <!-- controls + stats -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Listen port (loopback)" Style="{StaticResource Muted}" Margin="2,0,0,3" />
                                <TextBox x:Name="DnsPortBox" Width="96" Height="32" Text="53"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Port on 127.0.0.1. Standard DNS is 53; use another (e.g. 5335) if 53 is taken." />
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Upstream DNS" Style="{StaticResource Muted}" Margin="2,0,0,3" />
                                <TextBox x:Name="DnsUpstreamBox" Width="170" Height="32" Text="1.1.1.1"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Where allowed queries are forwarded (e.g. 1.1.1.1 or 8.8.8.8). Optional :port." />
                            </StackPanel>
                            <Button x:Name="DnsStartBtn" Content="Start resolver" Style="{StaticResource PrimaryButton}"
                                    Click="DnsStart_Click" Padding="16,9" VerticalAlignment="Bottom" />
                        </StackPanel>
                        <TextBlock x:Name="DnsResStatus" Style="{StaticResource Muted}" Margin="0,10,0,0" TextWrapping="Wrap"
                                   Text="Stopped. Start the resolver, then point a DNS query (or this PC's DNS) at 127.0.0.1 to use it." />

                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <CheckBox x:Name="DnsRedirectToggle" Style="{StaticResource SlideToggle}"
                                      Checked="DnsRedirect_Toggled" Unchecked="DnsRedirect_Toggled"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="Route this PC's DNS through GunWall" VerticalAlignment="Center"
                                       Margin="10,0,28,0"
                                       ToolTip="Points every physical adapter's DNS at 127.0.0.1. Your current DNS is captured first and restored automatically on exit. VPN tunnel adapters are never touched." />
                            <CheckBox x:Name="DnsGamingToggle" Style="{StaticResource SlideToggle}"
                                      Checked="DnsGaming_Toggled" Unchecked="DnsGaming_Toggled"
                                      VerticalAlignment="Center" IsEnabled="False" />
                            <TextBlock Text="Gaming Session (bypass)" VerticalAlignment="Center" Margin="10,0,0,0"
                                       ToolTip="One tap puts system DNS back on your normal servers for zero-overhead play; tap again after the match to route through GunWall." />
                        </StackPanel>
                        <TextBlock x:Name="DnsRedirectStatus" Style="{StaticResource Muted}" Margin="0,8,0,0" TextWrapping="Wrap"
                                   Text="System DNS untouched." />

                        <UniformGrid Rows="1" Columns="4" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock x:Name="DnsStatQueries" Text="0" Style="{StaticResource H2}" />
                                <TextBlock Text="Queries" Style="{StaticResource Muted}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock x:Name="DnsStatForwarded" Text="0" Style="{StaticResource H2}" />
                                <TextBlock Text="Forwarded" Style="{StaticResource Muted}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock x:Name="DnsStatCached" Text="0" Style="{StaticResource H2}" />
                                <TextBlock Text="Cached" Style="{StaticResource Muted}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock x:Name="DnsStatBlocked" Text="0" Style="{StaticResource H2}" />
                                <TextBlock Text="Blocked" Style="{StaticResource Muted}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- log + blocklist -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8" Margin="0,0,8,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="QUERY LOG" Style="{StaticResource SectionLabel}" Margin="4,2,0,8" />
                            <ListView x:Name="DnsLog" BorderThickness="0" Background="Transparent"
                                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Time" Width="84" DisplayMemberBinding="{Binding TimeText}" />
                                        <GridViewColumn Header="Domain" Width="320" DisplayMemberBinding="{Binding Domain}" />
                                        <GridViewColumn Header="Type" Width="64" DisplayMemberBinding="{Binding Type}" />
                                        <GridViewColumn Header="Action" Width="110">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ActionText}" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ActionText}" Value="Blocked">
                                                                        <Setter Property="Foreground" Value="{DynamicResource BlockText}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ActionText}" Value="Forwarded">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AllowText}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ActionText}" Value="Cached">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AllowText}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="BLOCKLIST" Style="{StaticResource SectionLabel}" Margin="0,0,0,2" />
                            <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,8"
                                       Text="One domain per line. Subdomains are blocked too (listing example.com also blocks ads.example.com). Hosts-style '0.0.0.0 domain' lines are accepted. Blocked lookups return NXDOMAIN." />
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                <Button x:Name="DnsPresetBtn" Content="Download ads + malware preset"
                                        Style="{StaticResource ActionButton}" Click="DnsPreset_Click"
                                        Padding="12,7" HorizontalAlignment="Left"
                                        ToolTip="Fetches the StevenBlack unified hosts list (~100k ad/malware domains) and blocks them in this resolver. Stored as dns-blocklist-preset.txt beside the app. Your own lines below stay separate." />
                                <TextBlock x:Name="DnsPresetStatus" Style="{StaticResource Muted}" Margin="0,6,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <Button x:Name="DnsClearCacheBtn" DockPanel.Dock="Bottom" Content="Clear resolver cache"
                                    Style="{StaticResource ActionButton}" Click="DnsClearCache_Click" Padding="16,8" Margin="0,6,0,0"
                                    ToolTip="Drops all cached answers so blocklist changes take effect immediately instead of waiting for TTLs to expire." />
                            <Button x:Name="DnsApplyBlockBtn" DockPanel.Dock="Bottom" Content="Apply blocklist"
                                    Style="{StaticResource PrimaryButton}" Click="DnsApplyBlock_Click" Padding="16,8" Margin="0,8,0,0" />
                            <TextBox x:Name="DnsBlockBox" AcceptsReturn="True" TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top" FontFamily="Consolas" />
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ========== §13 Notification center ========== -->
            <Grid x:Name="PanelAlerts" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Alerts" Style="{StaticResource H1}" />
                    <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap"
                               Text="Notable events in one place: protection turned on or off, lockdown engaged or lifted, and VirusTotal detections. Opening this page marks everything as read. Kept for this session (up to 200 entries)." />
                </StackPanel>
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8">
                    <Grid>
                        <TextBlock x:Name="AlertsEmpty" Text="Nothing yet - GunWall will note important events here."
                                   Style="{StaticResource Muted}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <ListView x:Name="AlertsList" BorderThickness="0" Background="Transparent"
                                  VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Time" Width="84" DisplayMemberBinding="{Binding TimeText}" />
                                    <GridViewColumn Header="Event" Width="240">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Kind}" Value="warn">
                                                                    <Setter Property="Foreground" Value="{DynamicResource BlockText}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="good">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AllowText}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Detail" Width="520" DisplayMemberBinding="{Binding Detail}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========== Packets Log ========== -->
            <Grid x:Name="PanelPackets" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Packets Log" Style="{StaticResource H1}" />
                        <TextBlock x:Name="PacketsSubtitle"
                                   Text="Live connection events from the kernel - allowed and blocked."
                                   Style="{StaticResource Muted}" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <TextBox x:Name="PacketsSearch" Style="{StaticResource SearchBox}"
                                 TextChanged="PacketsSearch_TextChanged"
                                 ToolTip="Search packets" Margin="0,0,8,0" />
                        <Button Content="Clear" Style="{StaticResource ActionButton}"
                                Click="ClearPackets_Click" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8">
                    <ListView x:Name="PacketsList" VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time" Width="84"
                                                DisplayMemberBinding="{Binding TimeText}" />
                                <GridViewColumn Header="Application" Width="150"
                                                DisplayMemberBinding="{Binding AppName}" />
                                <GridViewColumn Header="Proto" Width="56"
                                                DisplayMemberBinding="{Binding Protocol}" />
                                <GridViewColumn Header="Direction" Width="80"
                                                DisplayMemberBinding="{Binding Direction}" />
                                <GridViewColumn Header="Remote" Width="200"
                                                DisplayMemberBinding="{Binding RemoteEndpoint}" />
                                <GridViewColumn Header="Action" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="9" Padding="9,2" HorizontalAlignment="Left"
                                                    Background="{Binding ActionBrush}">
                                                <TextBlock Text="{Binding Action}" Foreground="#0E1117"
                                                           FontSize="11" FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Reason" Width="250">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Reason}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       ToolTip="{Binding Reason}" TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Grid>

            <!-- ========== Custom Rules ========== -->
            <Grid x:Name="PanelRules" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Custom Rules" Style="{StaticResource H1}" Margin="0,0,0,12" />

                <!-- Editor form -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="ADD A RULE" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="Block or allow traffic by remote address, port, protocol and direction."
                                   Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Action" Style="{StaticResource Muted}" Margin="2,0,0,3" />
                                <ComboBox x:Name="RuleAction" Width="82" Height="32">
                                    <ComboBoxItem Content="Block" IsSelected="True" />
                                    <ComboBoxItem Content="Allow" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Direction" Style="{StaticResource Muted}" Margin="2,0,0,3" />
                                <ComboBox x:Name="RuleDirection" Width="96" Height="32">
                                    <ComboBoxItem Content="Outbound" IsSelected="True" />
                                    <ComboBoxItem Content="Inbound" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Protocol" Style="{StaticResource Muted}" Margin="2,0,0,3" />
                                <ComboBox x:Name="RuleProtocol" Width="74" Height="32">
                                    <ComboBoxItem Content="Any" IsSelected="True" />
                                    <ComboBoxItem Content="TCP" />
                                    <ComboBoxItem Content="UDP" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Remote address" Style="{StaticResource Muted}" Margin="2,0,0,3" />
                                <TextBox x:Name="RuleAddress" Width="138" Height="32"
                                         VerticalContentAlignment="Center" ToolTip="Remote IPv4 (blank = any)" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Port" Style="{StaticResource Muted}" Margin="2,0,0,3" />
                                <TextBox x:Name="RulePort" Width="70" Height="32"
                                         VerticalContentAlignment="Center" ToolTip="Remote port (blank = any)" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Local port" Style="{StaticResource Muted}" Margin="2,0,0,3" />
                                <TextBox x:Name="RuleLocalPort" Width="74" Height="32"
                                         VerticalContentAlignment="Center" ToolTip="Local port on this PC (blank = any)" />
                            </StackPanel>
                            <Button Content="Add rule" Style="{StaticResource PrimaryButton}"
                                    Click="AddRule_Click" Padding="16,9" VerticalAlignment="Bottom" />
                        </StackPanel>
                        <TextBlock x:Name="RuleHint" Style="{StaticResource Muted}"
                                   Text="Tip: leave address and port blank to match all. Enter an IPv4 like 1.2.3.4."
                                   Margin="0,2,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Rules list -->
                <Border Grid.Row="2" Style="{StaticResource Card}" Padding="8">
                    <ListView x:Name="RulesList" VirtualizingPanel.IsVirtualizing="True">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Action" Width="80"
                                                DisplayMemberBinding="{Binding ActionText}" />
                                <GridViewColumn Header="Direction" Width="100"
                                                DisplayMemberBinding="{Binding DirectionText}" />
                                <GridViewColumn Header="Match" Width="280"
                                                DisplayMemberBinding="{Binding TargetText}" />
                                <GridViewColumn Header="Status" Width="120"
                                                DisplayMemberBinding="{Binding StatusText}" />
                                <GridViewColumn Header="" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Protected, Converter={StaticResource ProtectLabel}}"
                                                    Style="{StaticResource ActionButton}"
                                                    ToolTip="Protected rules can't be deleted until unprotected."
                                                    Click="ProtectRule_Click" Tag="{Binding Id}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Remove" Style="{StaticResource ActionButton}"
                                                    Click="RemoveRule_Click" Tag="{Binding Id}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <!-- Manual IP blocklist (curated lists live in the Security tab) -->
                <StackPanel Grid.Row="3" Margin="0,12,0,0">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="IP BLOCKLIST" Style="{StaticResource SectionLabel}" />
                            <TextBlock x:Name="BlocklistCount"
                                       Text="Paste IPv4 addresses or subnets (one per line) to block them outright."
                                       Style="{StaticResource Muted}" Margin="0,2,0,8" TextWrapping="Wrap" />
                            <TextBox x:Name="BlocklistInput" Height="68" AcceptsReturn="True"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Add to blocklist" Style="{StaticResource PrimaryButton}"
                                        Click="AddBlocklist_Click" Margin="0,0,8,0" Padding="16,8" />
                                <Button Content="Clear blocklist" Style="{StaticResource ActionButton}"
                                        Click="ClearBlocklist_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ========== Services ========== -->
            <Grid x:Name="PanelServices" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Windows Services" Style="{StaticResource H1}" />
                        <TextBlock Text="Services and the program that hosts each one. Block a service's host image directly."
                                   Style="{StaticResource Muted}" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <TextBox x:Name="ServicesSearch" Style="{StaticResource SearchBox}"
                                 TextChanged="ServicesSearch_TextChanged" Margin="0,0,8,0" ToolTip="Search services" />
                        <Button x:Name="ServicesRefreshBtn" Content="Refresh" Style="{StaticResource ActionButton}"
                                Click="RefreshServices_Click" />
                    </StackPanel>
                </Grid>
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8">
                    <ListView x:Name="ServicesList" VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Service" Width="220" DisplayMemberBinding="{Binding Display}" />
                                <GridViewColumn Header="Status" Width="90" DisplayMemberBinding="{Binding Status}" />
                                <GridViewColumn Header="Name" Width="160" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Block host" Style="{StaticResource ActionButton}"
                                                    Click="BlockService_Click" Tag="{Binding Name}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Grid>

            <!-- ========== Network Scanner ========== -->
            <Grid x:Name="PanelNetwork" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Network Scanner" Style="{StaticResource H1}" />
                        <TextBlock x:Name="NetworkSubtitle"
                                   Text="Discover devices on your local network (IP, MAC, host name)."
                                   Style="{StaticResource Muted}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Button x:Name="ScanBtn" Content="Scan network" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Padding="16,8"
                            Click="ScanNetwork_Click" />
                </Grid>
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8">
                    <ListView x:Name="DevicesList" VirtualizingPanel.IsVirtualizing="True">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="IP address" Width="160" DisplayMemberBinding="{Binding Ip}" />
                                <GridViewColumn Header="MAC address" Width="180" DisplayMemberBinding="{Binding Mac}" />
                                <GridViewColumn Header="Host" Width="280" DisplayMemberBinding="{Binding Host}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Grid>

            <!-- ========== System Rules ========== -->
            <Grid x:Name="PanelSystem" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="System Rules" Style="{StaticResource H1}" />
                        <TextBlock Text="A curated library of named firewall rules. Allow common services, or harden against risky traffic. Each applies immediately."
                                   Style="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap" MaxWidth="720" HorizontalAlignment="Left" />
                        <TextBlock x:Name="WfpCoverageText" Style="{StaticResource Muted}" Margin="0,6,0,0"
                                   HorizontalAlignment="Left" Text="" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <TextBox x:Name="SystemSearch" Width="190" Height="32" VerticalContentAlignment="Center"
                                 ToolTip="Search rules" Margin="0,0,8,0" TextChanged="SystemSearch_TextChanged" />
                        <Button Content="Secure baseline" Style="{StaticResource ActionButton}"
                                Click="SecureBaseline_Click"
                                ToolTip="Turn on a recommended set of hardening rules" />
                    </StackPanel>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="HARDEN AGAINST RISKY TRAFFIC" Style="{StaticResource SectionLabel}" Margin="0,0,0,8" />
                        <StackPanel x:Name="SystemBlockList" Margin="0,0,0,8" />
                        <TextBlock Text="ALLOW COMMON SERVICES" Style="{StaticResource SectionLabel}" Margin="0,8,0,8" />
                        <TextBlock Text="These permit a service outbound. They matter most when you've blocked traffic by default (strict mode or block-all-inbound)."
                                   Style="{StaticResource Muted}" Margin="0,0,0,8" TextWrapping="Wrap" MaxWidth="720" HorizontalAlignment="Left" />
                        <StackPanel x:Name="SystemAllowList" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ========== Security & Privacy ========== -->
            <Grid x:Name="PanelSecurity" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Security &amp; Privacy" Style="{StaticResource H1}" Margin="0,0,0,12" />
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="THREAT &amp; TELEMETRY BLOCKLISTS" Style="{StaticResource SectionLabel}" />
                                <TextBlock Text="Blocks known bad domains by category. Telemetry &amp; Windows Update use the Windows hosts file, falling back automatically to firewall rules if security software (e.g. Windows Defender) blocks the hosts file. Ads &amp; trackers is blocked at the DNS layer via AdGuard - fast and no hosts file needed. Click &quot;Update lists from online&quot; for the latest community lists (telemetry from WindowsSpyBlocker, ads/trackers from StevenBlack - both MIT)."
                                           Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />
                                <StackPanel x:Name="BlocklistCatList" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Button x:Name="UpdateListsBtn" Content="Update lists from online"
                                            Style="{StaticResource PrimaryButton}" Click="UpdateLists_Click"
                                            Padding="16,8" Margin="0,0,8,0" />
                                </StackPanel>
                                <TextBlock x:Name="BlocklistCatStatus" Style="{StaticResource Muted}" Margin="0,8,0,0" Text="" TextWrapping="Wrap" />
                                <ProgressBar x:Name="BlocklistProgress" IsIndeterminate="True" Height="3"
                                             Margin="0,8,0,0" Visibility="Collapsed" Background="Transparent" BorderThickness="0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="CUSTOM BLOCKLIST FILE" Style="{StaticResource SectionLabel}" />
                                <TextBlock Text="Point GunWall at your own list of domains to block. One domain per line; hosts-style lines (&quot;0.0.0.0 domain&quot;) and # comments are accepted. Your list is folded into the same hosts-file block as the categories above, and re-read whenever you choose a file."
                                           Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="CustomListBtn" Content="Choose file&#x2026;"
                                            Style="{StaticResource PrimaryButton}" Click="ChooseCustomList_Click"
                                            Padding="16,8" Margin="0,0,8,0" />
                                    <Button x:Name="CustomListClearBtn" Content="Clear"
                                            Style="{StaticResource ActionButton}" Click="ClearCustomList_Click" />
                                </StackPanel>
                                <TextBlock x:Name="CustomListStatus" Style="{StaticResource Muted}" Margin="0,8,0,0" Text="" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="GEOIP DATA SOURCE" Style="{StaticResource SectionLabel}" />
                                <TextBlock Text="Where country/ASN data comes from. &quot;Local database&quot; downloads the full IPv4 table into GunWall (use the Download button on the Connections tab). &quot;Self-hosted API server&quot; queries your own iptoasn-webservice instead - nothing to download, always fresh, and it resolves IPv6 too. Lookups are cached, so each address is fetched only once."
                                           Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ComboBox x:Name="GeoSourceCombo" Width="230" Height="30" SelectedIndex="0">
                                        <ComboBoxItem Content="Local database (download)" Tag="local" />
                                        <ComboBoxItem Content="Self-hosted API server" Tag="api" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBox x:Name="GeoApiUrlBox" Width="290" Height="30" Margin="0,0,8,0"
                                             VerticalContentAlignment="Center"
                                             ToolTip="e.g. http://192.168.1.50:53662 or https://geoip.example.com" />
                                    <Button Content="Save" Style="{StaticResource PrimaryButton}"
                                            Click="GeoSourceApply_Click" Padding="16,8" Margin="0,0,6,0" />
                                    <Button Content="Test" Style="{StaticResource ActionButton}"
                                            Click="GeoApiTest_Click" />
                                </StackPanel>
                                <TextBlock x:Name="GeoSourceStatus" Style="{StaticResource Muted}" Text="" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="COUNTRY &amp; ASN BLOCKING" Style="{StaticResource SectionLabel}" />
                                <TextBlock Text="Block an app (or every app) from connecting to a whole country, continent, or network operator (ASN), using the GeoIP data. Matching is reactive - GunWall blocks a remote the moment it sees a connection to it, so it is most effective against repeated or sustained traffic. IPv4 only. Set up a GeoIP data source above first."
                                           Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ComboBox x:Name="EntityTypeCombo" Width="120" Height="30" Margin="0,0,8,0" SelectedIndex="0">
                                        <ComboBoxItem Content="Country" Tag="country" />
                                        <ComboBoxItem Content="Continent" Tag="continent" />
                                        <ComboBoxItem Content="ASN" Tag="asn" />
                                    </ComboBox>
                                    <TextBox x:Name="EntityValueBox" Width="150" Height="30" Margin="0,0,8,0"
                                             VerticalContentAlignment="Center" ToolTip="e.g. RU &#xB7; EU &#xB7; AS13335" />
                                    <TextBlock Text="e.g. RU, EU, AS13335" Style="{StaticResource Muted}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock x:Name="EntityAppLabel" Text="Applies to: All apps" Style="{StaticResource Muted}"
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <Button Content="Choose app&#x2026;" Style="{StaticResource ActionButton}"
                                            Click="EntityChooseApp_Click" Margin="0,0,6,0" />
                                    <Button Content="All apps" Style="{StaticResource ActionButton}"
                                            Click="EntityAllApps_Click" Margin="0,0,12,0" />
                                    <Button Content="Add rule" Style="{StaticResource PrimaryButton}"
                                            Click="EntityAddRule_Click" Padding="16,8" />
                                </StackPanel>
                                <ItemsControl x:Name="EntityRuleList" Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource BgElevated}" CornerRadius="6"
                                                    Padding="10,6" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                               VerticalAlignment="Center" TextWrapping="Wrap" />
                                                    <Button Grid.Column="1" Content="Remove" Style="{StaticResource ActionButton}"
                                                            Tag="{Binding Id}" Click="EntityRemove_Click" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock x:Name="EntityStatus" Style="{StaticResource Muted}"
                                               VerticalAlignment="Center" Margin="0,0,12,0" Text="" TextWrapping="Wrap" />
                                    <Button Content="Clear active blocks" Style="{StaticResource ActionButton}"
                                            Click="EntityClearBlocks_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="FILTERING DNS" Style="{StaticResource SectionLabel}" />
                                <TextBlock Text="Point Windows at a filtering resolver for a second blocking layer that needs no list upkeep. AdGuard blocks ads &amp; trackers; Quad9 blocks malware &amp; phishing. Applies to all active adapters."
                                           Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="DnsCombo" Width="320" Height="30" Margin="0,0,8,0" />
                                    <Button Content="Apply DNS" Style="{StaticResource ActionButton}" Click="DnsApply_Click" />
                                </StackPanel>
                                <TextBlock x:Name="DnsStatus" Style="{StaticResource Muted}" Margin="0,8,0,0" Text="" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ========== Activity ========== -->
            <Grid x:Name="PanelActivity" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Activity" Style="{StaticResource H1}" />
                        <TextBlock Text="New connections as they appear. Local only - nothing leaves this PC."
                                   Style="{StaticResource Muted}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Content="Clear" Style="{StaticResource ActionButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Click="ClearActivity_Click" />
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8">
                    <ListView x:Name="ActivityList" VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time" Width="90"
                                                DisplayMemberBinding="{Binding TimeText}" />
                                <GridViewColumn Header="Process" Width="200"
                                                DisplayMemberBinding="{Binding ProcessName}" />
                                <GridViewColumn Header="Event" Width="460"
                                                DisplayMemberBinding="{Binding Detail}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Grid>

            <!-- ========== Settings ========== -->
            <Grid x:Name="PanelSettings" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Settings" Style="{StaticResource H1}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="ApplyStatus" Text="" Style="{StaticResource Muted}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                        <Button x:Name="ApplyButton" Content="Apply" Style="{StaticResource PrimaryButton}"
                                IsEnabled="False" Click="ApplySettings_Click" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="FIREWALL MODE" Style="{StaticResource SectionLabel}" />
                            <TextBlock Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap"
                                       Text="Alert mode allows new apps and notifies you. Strict mode takes full control: everything is blocked except apps you explicitly allow. Core Windows networking (svchost, DNS) and loopback are auto-allowed so your connection keeps working." />
                            <RadioButton x:Name="AlertModeRadio" Content="Alert mode (recommended)"
                                         GroupName="FwMode" IsChecked="True"
                                         Foreground="{DynamicResource TextPrimary}"
                                         Checked="Mode_Changed" Margin="0,0,0,6" />
                            <RadioButton x:Name="StrictModeRadio" Content="Strict mode - block everything except allowed apps"
                                         GroupName="FwMode"
                                         Foreground="{DynamicResource TextPrimary}"
                                         Checked="Mode_Changed" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="CONNECTION ALERTS" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="Show a popup the first time a new app connects to the network, with one-click Allow / Block."
                                       Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />
                            <CheckBox x:Name="AlertsCheck" Content="Alert on new apps"
                                      Foreground="{DynamicResource TextPrimary}"
                                      Checked="AlertsCheck_Changed" Unchecked="AlertsCheck_Changed" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="APPEARANCE - CATEGORY COLORS" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="Customise the colored dot next to each app. Enter a hex color like #30D158, then Apply."
                                       Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" /><ColumnDefinition Width="150" /><ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ColorSignedSwatch" Grid.Column="0" Width="14" Height="14" CornerRadius="3" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Valid signature" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" />
                                <TextBox x:Name="ColorSignedBox" Grid.Column="2" Width="110" HorizontalAlignment="Left"
                                         Background="{DynamicResource BgElevated}" Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource BorderBrush}" Padding="4,2" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" /><ColumnDefinition Width="150" /><ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ColorUnsignedSwatch" Grid.Column="0" Width="14" Height="14" CornerRadius="3" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Unsigned" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" />
                                <TextBox x:Name="ColorUnsignedBox" Grid.Column="2" Width="110" HorizontalAlignment="Left"
                                         Background="{DynamicResource BgElevated}" Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource BorderBrush}" Padding="4,2" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" /><ColumnDefinition Width="150" /><ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ColorSystemSwatch" Grid.Column="0" Width="14" Height="14" CornerRadius="3" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Windows / system" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" />
                                <TextBox x:Name="ColorSystemBox" Grid.Column="2" Width="110" HorizontalAlignment="Left"
                                         Background="{DynamicResource BgElevated}" Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource BorderBrush}" Padding="4,2" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" /><ColumnDefinition Width="150" /><ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ColorInvalidSwatch" Grid.Column="0" Width="14" Height="14" CornerRadius="3" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Invalid signature" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" />
                                <TextBox x:Name="ColorInvalidBox" Grid.Column="2" Width="110" HorizontalAlignment="Left"
                                         Background="{DynamicResource BgElevated}" Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource BorderBrush}" Padding="4,2" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" /><ColumnDefinition Width="150" /><ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ColorUnknownSwatch" Grid.Column="0" Width="14" Height="14" CornerRadius="3" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Unknown" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" />
                                <TextBox x:Name="ColorUnknownBox" Grid.Column="2" Width="110" HorizontalAlignment="Left"
                                         Background="{DynamicResource BgElevated}" Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource BorderBrush}" Padding="4,2" />
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Apply colors" Click="ApplyColors_Click" Style="{StaticResource ActionButton}" Margin="0,0,8,0" />
                                <Button Content="Reset to defaults" Click="ResetColors_Click" Style="{StaticResource ActionButton}" />
                                <TextBlock x:Name="ColorStatus" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="12,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="PREFERENCES" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="General behaviour. Staged - press Apply to save."
                                       Style="{StaticResource Muted}" Margin="0,2,0,10" />
                            <CheckBox x:Name="StartMinimizedCheck" Content="Start minimized to tray"
                                      Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"
                                      Checked="Pref_Changed" Unchecked="Pref_Changed" />
                            <CheckBox x:Name="RunAtStartupCheck" Content="Run GunWall when Windows starts"
                                      Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"
                                      Checked="Pref_Changed" Unchecked="Pref_Changed" />
                            <CheckBox x:Name="EventLogCheck" Content="Send firewall events to the Windows Event Log"
                                      Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"
                                      Checked="Pref_Changed" Unchecked="Pref_Changed" />
                            <CheckBox x:Name="NotifSoundCheck" Content="Play a sound on notification popups"
                                      Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"
                                      Checked="Pref_Changed" Unchecked="Pref_Changed" />
                            <CheckBox x:Name="TrayNotifCheck" Content="Show a tray notification when a new app is detected"
                                      Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"
                                      Checked="Pref_Changed" Unchecked="Pref_Changed" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,6">
                                <TextBlock Text="Popup stays open for" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,8,0" />
                                <ComboBox x:Name="PopupTimeoutCombo" Width="120" Height="30"
                                          SelectionChanged="Pref_Changed">
                                    <ComboBoxItem Content="15 seconds" Tag="15" />
                                    <ComboBoxItem Content="30 seconds" Tag="30" />
                                    <ComboBoxItem Content="60 seconds" Tag="60" />
                                    <ComboBoxItem Content="Never (wait for me)" Tag="0" />
                                </ComboBox>
                                <TextBlock Text="then" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimary}" Margin="12,0,8,0" />
                                <ComboBox x:Name="PopupDefaultCombo" Width="100" Height="30"
                                          SelectionChanged="Pref_Changed">
                                    <ComboBoxItem Content="Allow" Tag="allow" />
                                    <ComboBoxItem Content="Block" Tag="block" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <CheckBox x:Name="PacketLogFileCheck" Content="Log packets to a CSV file"
                                          Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                                          Checked="Pref_Changed" Unchecked="Pref_Changed" />
                                <Button Content="Open log folder" Style="{StaticResource ActionButton}"
                                        Click="OpenLogFolder_Click" Margin="12,0,0,0" Padding="10,3" />
                            </StackPanel>
                            <CheckBox x:Name="FullscreenSilentCheck" Content="Silence popups while a fullscreen app or game is running"
                                      Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"
                                      Checked="Pref_Changed" Unchecked="Pref_Changed" />
                            <CheckBox x:Name="ConfirmClearCheck" Content="Confirm before clearing the Activity / Packets logs"
                                      Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"
                                      Checked="Pref_Changed" Unchecked="Pref_Changed" />
                            <CheckBox x:Name="ConfirmExitCheck" Content="Always confirm before exiting GunWall"
                                      Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"
                                      Checked="Pref_Changed" Unchecked="Pref_Changed" />
                            <CheckBox x:Name="KeepUnusedCheck" Content="Keep apps with no rule and no connections in the list"
                                      Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"
                                      Checked="Pref_Changed" Unchecked="Pref_Changed" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,6">
                                <TextBlock Text="Keep at most" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,8,0" />
                                <ComboBox x:Name="MaxLogEntriesCombo" Width="130" Height="30"
                                          SelectionChanged="Pref_Changed">
                                    <ComboBoxItem Content="500 entries" Tag="500" />
                                    <ComboBoxItem Content="1000 entries" Tag="1000" />
                                    <ComboBoxItem Content="5000 entries" Tag="5000" />
                                    <ComboBoxItem Content="Unlimited" Tag="0" />
                                </ComboBox>
                                <TextBlock Text="live rows; rotate CSV at" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimary}" Margin="12,0,8,0" />
                                <ComboBox x:Name="MaxLogFileCombo" Width="90" Height="30"
                                          SelectionChanged="Pref_Changed">
                                    <ComboBoxItem Content="2 MB" Tag="2" />
                                    <ComboBoxItem Content="5 MB" Tag="5" />
                                    <ComboBoxItem Content="20 MB" Tag="20" />
                                    <ComboBoxItem Content="50 MB" Tag="50" />
                                </ComboBox>
                            </StackPanel>
                            <CheckBox x:Name="AlwaysOnTopCheck" Content="Keep window always on top"
                                      Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"
                                      Checked="Pref_Changed" Unchecked="Pref_Changed" />
                            <CheckBox x:Name="HashesCheck" Content="Compute SHA-256 hash of apps (tamper detection)"
                                      Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"
                                      Checked="Pref_Changed" Unchecked="Pref_Changed" />
                            <CheckBox x:Name="EtwMeterCheck"
                                      Content="Experimental: precise per-app data metering (ETW kernel session; falls back to the estimate on any failure)"
                                      Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"
                                      Checked="Pref_Changed" Unchecked="Pref_Changed" />
                            <CheckBox x:Name="ExperimentalEventsCheck"
                                      Content="Experimental: kernel event detection (catches more apps, may be unstable)"
                                      Foreground="{DynamicResource TextPrimary}"
                                      Checked="Pref_Changed" Unchecked="Pref_Changed" />
                            <TextBlock Text="If GunWall becomes unstable after enabling this, turn it off and restart. Restart required to take effect."
                                       Style="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="PROFILE (RULES BACKUP)" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="Export all your rules and settings to a file, or import them on another machine."
                                       Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Export profile" Style="{StaticResource ActionButton}"
                                        Click="ExportProfile_Click" Margin="0,0,8,0" />
                                <Button Content="Import profile" Style="{StaticResource ActionButton}"
                                        Click="ImportProfile_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="WINDOWS FIREWALL" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="GunWall and Windows Defender Firewall both use the Windows Filtering Platform. Running both can cause confusing conflicts - you can turn Windows Firewall off here, or import its existing block rules into GunWall."
                                       Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />
                            <TextBlock x:Name="WinFwStatus" Text="Checking Windows Firewall status..."
                                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Turn Windows Firewall off" Style="{StaticResource ActionButton}"
                                        Click="WinFwOff_Click" Margin="0,0,8,0" />
                                <Button Content="Turn it back on" Style="{StaticResource ActionButton}"
                                        Click="WinFwOn_Click" Margin="0,0,8,0" />
                                <Button Content="Refresh status" Style="{StaticResource ActionButton}"
                                        Click="WinFwRefresh_Click" Margin="0,0,8,0" />
                                <Button Content="Import its block rules" Style="{StaticResource ActionButton}"
                                        Click="WinFwImport_Click" />
                            </StackPanel>
                            <TextBlock x:Name="WinFwImportStatus" Style="{StaticResource Muted}" Margin="0,8,0,0" Text="" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="DIAGNOSTICS" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="Hit a problem? Export a diagnostics bundle and send it over. It packages GunWall's real-time log (including any errors as they happened), your settings with secrets removed, the active rules and blocklist/DNS state, the hosts block, and your network/firewall configuration - everything needed to pinpoint the issue. No browsing history or personal data is included."
                                       Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="ExportDiagBtn" Content="Export diagnostics (.zip)"
                                        Style="{StaticResource PrimaryButton}" Click="ExportDiag_Click"
                                        Padding="16,8" Margin="0,0,8,0" />
                                <Button Content="Open data folder" Style="{StaticResource ActionButton}"
                                        Click="OpenLogFolder_Click" />
                            </StackPanel>
                            <TextBlock x:Name="DiagStatus" Style="{StaticResource Muted}" Margin="0,8,0,0" Text="" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="APP HEALTH" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="Live view of GunWall's own internals - the same counters the diagnostics export records. Updates every second while this page is open."
                                       Style="{StaticResource Muted}" Margin="0,4,0,10" TextWrapping="Wrap" />
                            <TextBlock x:Name="HealthPipeline" Text="Monitoring: -" Margin="0,2,0,0" TextWrapping="Wrap" />
                            <TextBlock x:Name="HealthGeo" Text="GeoIP: -" Margin="0,6,0,0" TextWrapping="Wrap" />
                            <TextBlock x:Name="HealthDns" Text="DNS resolver: -" Margin="0,6,0,0" TextWrapping="Wrap" />
                            <TextBlock x:Name="HealthVt" Text="VirusTotal: -" Margin="0,6,0,0" TextWrapping="Wrap" />
                            <TextBlock x:Name="HealthEtw" Text="ETW meter: -" Margin="0,6,0,0" TextWrapping="Wrap" />
                            <TextBlock x:Name="HealthRules" Text="Rules: -" Margin="0,6,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="CONNECTIVITY CHECK" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="On hotel / airport Wi-Fi, a captive portal intercepts traffic until you log in - which can look like GunWall blocking everything. Check here, and if a portal is found, Portal mode pauses filtering for 5 minutes so you can reach the login page. Protection resumes automatically."
                                       Style="{StaticResource Muted}" Margin="0,4,0,10" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="CheckPortalBtn" Content="Check now" Style="{StaticResource ActionButton}"
                                        Click="CheckPortal_Click" Padding="14,8" Margin="0,0,8,0" />
                                <Button x:Name="PortalModeBtn" Content="Portal mode (pause 5 min)" Style="{StaticResource PrimaryButton}"
                                        Click="PortalMode_Click" Padding="14,8" />
                            </StackPanel>
                            <TextBlock x:Name="PortalStatus" Style="{StaticResource Muted}" Margin="0,10,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="RULE PROFILES" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="Save your current per-app allow/block rules as a named profile (e.g. Gaming, Work) and switch between them in one click. Apps not captured in a profile are left untouched; muted apps keep their setting."
                                       Style="{StaticResource Muted}" Margin="0,4,0,10" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="ProfileCombo" Width="200" Margin="0,0,8,0" />
                                <Button x:Name="ProfileApplyBtn" Content="Apply profile" Style="{StaticResource PrimaryButton}"
                                        Click="ProfileApply_Click" Padding="14,8" Margin="0,0,24,0" />
                                <TextBox x:Name="ProfileNameBox" Width="170" Height="32" VerticalContentAlignment="Center"
                                         Margin="0,0,8,0" ToolTip="Name for the new profile (e.g. Gaming)" />
                                <Button x:Name="ProfileSaveBtn" Content="Save current as" Style="{StaticResource ActionButton}"
                                        Click="ProfileSave_Click" Padding="14,8" />
                            </StackPanel>
                            <TextBlock x:Name="RuleProfileStatus" Style="{StaticResource Muted}" Margin="0,10,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="PROFILES" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="Save the current rules and settings as a named profile, then switch between profiles (e.g. Home, Work, Travel)."
                                       Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <ComboBox x:Name="ProfilesCombo" Width="200" Margin="0,0,8,0" />
                                <Button Content="Load" Style="{StaticResource ActionButton}"
                                        Click="LoadProfile_Click" Margin="0,0,8,0" />
                                <Button Content="Delete" Style="{StaticResource ActionButton}"
                                        Click="DeleteProfile_Click" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="NewProfileName" Width="200" Height="30"
                                         VerticalContentAlignment="Center" Margin="0,0,8,0"
                                         ToolTip="New profile name" />
                                <Button Content="Save current as profile" Style="{StaticResource PrimaryButton}"
                                        Click="SaveProfile_Click" Padding="14,7" />
                            </StackPanel>
                            <TextBlock x:Name="ProfileStatus" Style="{StaticResource Muted}" Margin="0,8,0,0" Text="" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="BACKUPS" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="Versioned snapshots of your rules and settings. Restore points let you roll back if a change goes wrong. The newest 15 are kept."
                                       Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />
                            <CheckBox x:Name="AutoBackupCheck" Content="Automatically back up on each launch"
                                      Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"
                                      Checked="Pref_Changed" Unchecked="Pref_Changed" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ComboBox x:Name="BackupsCombo" Width="240" Height="30" Margin="0,0,8,0" />
                                <Button Content="Restore" Style="{StaticResource ActionButton}"
                                        Click="RestoreBackup_Click" Margin="0,0,8,0" />
                                <Button Content="Back up now" Style="{StaticResource ActionButton}"
                                        Click="BackupNow_Click" />
                            </StackPanel>
                            <TextBlock x:Name="BackupStatus" Style="{StaticResource Muted}" Margin="0,4,0,0" Text="" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="VIRUSTOTAL" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="Add your VirusTotal API key and GunWall automatically checks each app's file hash in the background, showing the verdict in the Apps list (right-click an app for an on-demand scan). Only the file hash is sent, never the file. Results are cached; the free tier is checked at a rate-limit-safe pace."
                                       Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal">
                                <PasswordBox x:Name="VtApiKeyBox" Width="280" Padding="8,6"
                                             Background="{DynamicResource BgElevated}"
                                             Foreground="{DynamicResource TextPrimary}"
                                             BorderBrush="{DynamicResource BorderBrush}" Margin="0,0,8,0" />
                                <Button Content="Save key" Style="{StaticResource ActionButton}"
                                        Click="SaveVtKey_Click" />
                            </StackPanel>
                            <TextBlock x:Name="VtKeyStatus" Style="{StaticResource Muted}" Margin="0,8,0,0" Text="" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="REFRESH INTERVAL" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="How often connections and the graph update. Slower = lower CPU."
                                       Style="{StaticResource Muted}" Margin="0,2,0,10" />
                            <ComboBox x:Name="IntervalCombo" Width="160" HorizontalAlignment="Left"
                                      SelectionChanged="IntervalCombo_Changed">
                                <ComboBoxItem Content="1 second" IsSelected="True" Tag="1000" />
                                <ComboBoxItem Content="2 seconds" Tag="2000" />
                                <ComboBoxItem Content="5 seconds" Tag="5000" />
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="RESET FIREWALL" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="Removes every filter GunWall has created (including persistent ones) and clears saved rules. Run this before uninstalling."
                                       Style="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap" />
                            <Button Content="Remove all GunWall filtering"
                                    Style="{StaticResource ActionButton}" HorizontalAlignment="Left"
                                    Click="RemoveAll_Click" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="ABOUT" Style="{StaticResource SectionLabel}" />
                            <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,0" TextWrapping="Wrap"
                                       x:Name="AboutText"
                                       Text="GunWall - free, open-source, no telemetry. Built on the Windows Filtering Platform." />
                            <TextBlock Margin="0,6,0,0">
                                <Hyperlink NavigateUri="https://github.com/ox1d3x3/gunwall"
                                           RequestNavigate="Repo_RequestNavigate"
                                           Foreground="{StaticResource Accent}">github.com/ox1d3x3/gunwall</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </Grid>

        </Grid>
        </Grid>

        <!-- ===================== Persistent footer status bar ===================== -->
        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,7">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Ellipse x:Name="FooterProtDot" Width="8" Height="8" Fill="#FF9F0A"
                             VerticalAlignment="Center" Margin="0,0,7,0" />
                    <TextBlock x:Name="FooterProtText" Text="Starting..." FontSize="11.5"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                               Margin="0,0,22,0" />
                    <Ellipse Width="8" Height="8" Fill="{StaticResource InboundBrush}"
                             VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock x:Name="FooterDown" Text="0 B/s" FontSize="11.5"
                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"
                               Margin="0,0,18,0" />
                    <Ellipse Width="8" Height="8" Fill="{StaticResource OutboundBrush}"
                             VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock x:Name="FooterUp" Text="0 B/s" FontSize="11.5"
                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <TextBlock x:Name="FooterMeter" Text="Estimated metering" FontSize="11"
                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"
                               Margin="0,0,18,0" />
                    <TextBlock x:Name="FooterAlerts" Text="No new alerts" FontSize="11.5"
                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
