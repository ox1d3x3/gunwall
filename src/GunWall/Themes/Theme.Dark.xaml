<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== DARK THEME (AMOLED black) =====
         True-black window with neutral, Apple-style lifted surfaces: near-black
         cards, hairline separators, warm-white text and soft tinted status pills. -->
    <SolidColorBrush x:Key="BgPrimary" Color="#000000" />
    <SolidColorBrush x:Key="BgSecondary" Color="#0B0B0C" />
    <SolidColorBrush x:Key="BgCard" Color="#131315" />
    <SolidColorBrush x:Key="BgElevated" Color="#1D1D20" />
    <SolidColorBrush x:Key="BorderBrush" Color="#2A2A2E" />
    <SolidColorBrush x:Key="TextPrimary" Color="#F5F5F7" />
    <SolidColorBrush x:Key="TextSecondary" Color="#98989F" />

    <!-- Soft status fills + foregrounds (pills) -->
    <SolidColorBrush x:Key="AllowFill" Color="#0E2B19" />
    <SolidColorBrush x:Key="AllowText" Color="#30D158" />
    <SolidColorBrush x:Key="BlockFill" Color="#331A18" />
    <SolidColorBrush x:Key="BlockText" Color="#FF6961" />
    <SolidColorBrush x:Key="AccentSoft" Color="#0E2A4F" />

    <sys:Boolean xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="IsDarkTheme">True</sys:Boolean>
</ResourceDictionary>
