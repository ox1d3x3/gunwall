<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ======================= DARK THEME PALETTE =======================
         Neutral near-black surfaces with clear elevation steps and high-
         contrast text so information pops. The cyan/violet accent is shared
         with the light theme (defined in Controls.xaml) so only the neutrals
         change between themes. -->
    <SolidColorBrush x:Key="BgPrimary" Color="#0F1115" />
    <SolidColorBrush x:Key="BgSecondary" Color="#16181D" />
    <SolidColorBrush x:Key="BgCard" Color="#1B1E24" />
    <SolidColorBrush x:Key="BgElevated" Color="#252932" />
    <SolidColorBrush x:Key="BorderBrush" Color="#2C313B" />
    <SolidColorBrush x:Key="TextPrimary" Color="#EDEFF2" />
    <SolidColorBrush x:Key="TextSecondary" Color="#969DA8" />

    <!-- Title bar hint: dark -->
    <sys:Boolean xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="IsDarkTheme">True</sys:Boolean>

</ResourceDictionary>
