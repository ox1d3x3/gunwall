<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== LIGHT THEME (clean white) =====
         Clean white surfaces with soft borders and slate text. -->
    <SolidColorBrush x:Key="BgPrimary" Color="#FBFCFD" />
    <SolidColorBrush x:Key="BgSecondary" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BgCard" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BgElevated" Color="#F1F4F8" />
    <SolidColorBrush x:Key="BorderBrush" Color="#E6EAEF" />
    <SolidColorBrush x:Key="TextPrimary" Color="#2B3440" />
    <SolidColorBrush x:Key="TextSecondary" Color="#8A95A3" />

    <!-- Soft status fills + foregrounds (pills) -->
    <SolidColorBrush x:Key="AllowFill" Color="#E7F6EC" />
    <SolidColorBrush x:Key="AllowText" Color="#2E9E54" />
    <SolidColorBrush x:Key="BlockFill" Color="#FCEBEA" />
    <SolidColorBrush x:Key="BlockText" Color="#D6534F" />
    <SolidColorBrush x:Key="AccentSoft" Color="#EAF2FB" />

    <sys:Boolean xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="IsDarkTheme">False</sys:Boolean>
</ResourceDictionary>
