<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ======================= LIGHT THEME PALETTE =======================
         Clean white/off-white surfaces. The page is a soft off-white so that
         pure-white cards lift off it; text is near-black for strong contrast.
         Accent colors are shared with the dark theme. -->
    <SolidColorBrush x:Key="BgPrimary" Color="#F4F6F8" />
    <SolidColorBrush x:Key="BgSecondary" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BgCard" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BgElevated" Color="#E9ECF1" />
    <SolidColorBrush x:Key="BorderBrush" Color="#DCE0E6" />
    <SolidColorBrush x:Key="TextPrimary" Color="#161A20" />
    <SolidColorBrush x:Key="TextSecondary" Color="#5C6573" />

    <!-- Title bar hint: light -->
    <sys:Boolean xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="IsDarkTheme">False</sys:Boolean>

</ResourceDictionary>
